<Window x:Class="TudomanyosGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TudomanyosGUI"
        mc:Ignorable="d"
        Title="Tudományos előadók adatai" Width="400" SizeToContent="Height">
    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label
            Grid.Row="0"
            Content="Kérem válasszon kategóriát!"
            Padding="0"
            Margin="5,5,5,0" />
        <ComboBox
            Grid.Row="1"
            ItemsSource="{Binding Kategoriak}"
            SelectedItem="{Binding KivalasztottKategoria}"
            DisplayMemberPath="Kategoria"
            Margin="5" />

        <Label
            Grid.Row="2"
            Content="Kérem válasszon előadót!"
            IsEnabled="{Binding VanKivalasztottKategoria}"
            Padding="0"
            Margin="5,5,5,0" />
        <ComboBox
            Grid.Row="3"
            ItemsSource="{Binding ValaszthatoEloadok}"
            SelectedItem="{Binding KivalasztottEloado}"
            IsEnabled="{Binding VanKivalasztottKategoria}"
            DisplayMemberPath="Nev"
            Margin="5" />

        <ListBox
            Grid.Row="4"
            Margin="5"
            MinHeight="400"
            ItemsSource="{Binding KivalasztottEloado.Programok}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="2"
                            Text="Dátum" />
                        <TextBox
                            Margin="2"
                            Text="{Binding Datum}"
                            IsReadOnly="True" />

                        <TextBlock
                            Margin="2"
                            Text="Időpont" />
                        <TextBox
                            Margin="2"
                            Text="{Binding KezdoIdopont}"
                            IsReadOnly="True" />

                        <TextBlock
                            Margin="2"
                            Text="Hossz" />
                        <TextBox
                            Margin="2"
                            Text="{Binding Hossz}"
                            IsReadOnly="True" />
                        <TextBlock
                            Margin="2"
                            Text="perc" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
