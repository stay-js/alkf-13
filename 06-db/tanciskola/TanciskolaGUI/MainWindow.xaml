<Window x:Class="TanciskolaGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TanciskolaGUI"
        mc:Ignorable="d"
        Title="Tánctanárok adatai" Width="400" SizeToContent="Height">
    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>

    <StackPanel Margin="10">
        <Label
            Content="Kérem válasszon tánctípust"
            Padding="0"
            Margin="0,0,0,5" />
        <ComboBox
            ItemsSource="{Binding Tancok}"
            SelectedItem="{Binding KivalasztottTanc}"
            DisplayMemberPath="TancTipus"
            Margin="0,0,0,10" />

        <Label
            Content="Kérem válasszon tánctanárt"
            Padding="0"
            Margin="0,0,0,5" />
        <ComboBox
            ItemsSource="{Binding Tanarok}"
            SelectedItem="{Binding KivalasztottTanar}"
            IsEnabled="{Binding VanKivalasztottTanc}"
            DisplayMemberPath="Nev"
            Margin="0,0,0,10" />

        <GroupBox Header="A tánctanár órái" Margin="0,0,0,10">
            <ListBox
                MinHeight="300"
                ItemsSource="{Binding KivalasztottTanar.Orak}" />
        </GroupBox>
    </StackPanel>
</Window>
